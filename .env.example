# Which LLM provider to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Notion docs sync
NOTION_TOKEN=
NOTION_PAGE_ID=

# Optional: GitHub token raises rate limits and enables private repos
GITHUB_TOKEN=
